# Rust build output
/target/

# Rust backup files
**/*.rs.bk

# Keep Cargo.lock tracked for Monad.
# Monad is an executable developer tool, so Cargo.lock should be committed.

# Environment and secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# Editor and IDE local state
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Temporary files
tmp/
temp/
.tmp/
.cache/

# Python local artifacts used by helper scripts
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node artifacts for future optional surfaces or fixtures
node_modules/
dist/
build/
coverage/
.turbo/
.next/
.vite/

# Monad local/generated operational state
.monad/cache/
.monad/tmp/
.monad/local/
.monad/**/*.log

# Generated archives
*.tar
*.tar.gz
*.zip
# Monad generated context artifacts
.monad/context/generated/

# Imported/generated DeepWiki artifacts must not be treated as first-party dependencies.
docs/wiki/.artifacts/
docs/wiki/deepwiki-dump-*/package.json
docs/wiki/deepwiki-dump-*/package-lock.json
docs/wiki/deepwiki-dump-*/pnpm-lock.yaml
docs/wiki/deepwiki-dump-*/bun.lockb
docs/wiki/deepwiki-dump-*/yarn.lock
docs/wiki/deepwiki-dump-*/node_modules/
